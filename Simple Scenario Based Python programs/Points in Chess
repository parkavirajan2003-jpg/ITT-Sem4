t=int(input("Enter no of test cases:"))
for i in range(1,t+1):
        X=int(input("Enter prize pool:"))
        result=list(input("Enter match result"))
        chandrupoints=0
        nirmalpoints=0
        for i in result:
                if (i=='C'):
                        chandrupoints+=2
                elif(i=='N'):
                        nirmalpoints+=2
                else:
                        chandrupoints+=1
                        nirmalpoints+=1
        if(chandrupoints>nirmalpoints):
                print(60*X)
        elif(chandrupoints==nirmalpoints):
                print(55*X)
        else:
                print(44*X)
